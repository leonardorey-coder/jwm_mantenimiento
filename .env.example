# ============================================
# CONFIGURACIÓN DE POSTGRESQL - BASE DE DATOS LOCAL
# ============================================

# Configuración para desarrollo local (macOS con Homebrew PostgreSQL)
# Para conectarse a la base de datos local jwmantto:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jwmantto
DB_USER=leonardocruz
DB_PASSWORD=

# String de conexión completo (alternativo)
# DATABASE_URL=postgresql://leonardocruz@localhost:5432/jwmantto

# Configuración del pool de conexiones
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# SSL (deshabilitado para desarrollo local)
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# ============================================
# NOTAS PARA CONEXIÓN LOCAL
# ============================================
# 1. Asegúrate de que PostgreSQL esté corriendo:
#    brew services start postgresql@16
#
# 2. Verifica la conexión:
#    psql -U leonardocruz -d jwmantto
#
# 3. Si necesitas crear la base de datos:
#    createdb -U leonardocruz jwmantto
#
# 4. Para restaurar desde backup:
#    psql -U leonardocruz -d jwmantto -f db/backup_jwmantto_YYYY-MM-DD_HH-MM-SS.sql

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=jwm_mant_secret_key_2025_change_in_production
JWT_EXPIRATION=1h
REFRESH_TOKEN_EXPIRATION=7d

# ============================================
# ADMINISTRADOR DE CONTACTO
# ============================================
ADMIN_NAME=Fidel Cruz Lozada
ADMIN_EMAIL=fcruz@grupodiestra.com
ADMIN_PHONE=+526242371063

# ============================================
# SERVIDOR
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# EJEMPLOS PARA ENTORNOS EN LA NUBE
# ============================================

# --- Azure Database for PostgreSQL ---
# DB_HOST=tu-servidor.postgres.database.azure.com
# DB_PORT=5432
# DB_NAME=jwmantto
# DB_USER=tu_usuario@tu-servidor
# DB_PASSWORD=tu_password_seguro
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# --- AWS RDS PostgreSQL ---
# DB_HOST=tu-instancia.abc123.us-east-1.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=jwmantto
# DB_USER=postgres
# DB_PASSWORD=tu_password_seguro
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# --- Heroku Postgres ---
# DATABASE_URL=postgres://usuario:password@host:5432/database
# (Heroku proporciona DATABASE_URL directamente)

# --- Railway / Render ---
# DB_HOST=containers-us-west-xxx.railway.app
# DB_PORT=5432
# DB_NAME=railway
# DB_USER=postgres
# DB_PASSWORD=tu_password_seguro
# DB_SSL=true

# ============================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================

# Puerto del servidor Express
PORT=3001

# Modo de desarrollo/producción
NODE_ENV=development

# ============================================
# MIGRACIÓN DE DATOS
# ============================================

# Ruta a la base de datos SQLite (si deseas migrar datos)
SQLITE_DB_PATH=./db/jwmantto.db
