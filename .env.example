# ============================================
# CONFIGURACIÓN DE POSTGRESQL
# ============================================

# Configuración para desarrollo local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jwmantto
DB_USER=postgres
DB_PASSWORD=postgres

# Configuración del pool de conexiones
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# SSL (requerido para la mayoría de bases de datos en la nube)
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ============================================
# EJEMPLOS PARA ENTORNOS EN LA NUBE
# ============================================

# --- Azure Database for PostgreSQL ---
# DB_HOST=tu-servidor.postgres.database.azure.com
# DB_PORT=5432
# DB_NAME=jwmantto
# DB_USER=tu_usuario@tu-servidor
# DB_PASSWORD=tu_password_seguro
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# --- AWS RDS PostgreSQL ---
# DB_HOST=tu-instancia.abc123.us-east-1.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=jwmantto
# DB_USER=postgres
# DB_PASSWORD=tu_password_seguro
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# --- Heroku Postgres ---
# DATABASE_URL=postgres://usuario:password@host:5432/database
# (Heroku proporciona DATABASE_URL directamente)

# --- Railway / Render ---
# DB_HOST=containers-us-west-xxx.railway.app
# DB_PORT=5432
# DB_NAME=railway
# DB_USER=postgres
# DB_PASSWORD=tu_password_seguro
# DB_SSL=true

# ============================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================

# Puerto del servidor Express
PORT=3001

# Modo de desarrollo/producción
NODE_ENV=development

# ============================================
# MIGRACIÓN DE DATOS
# ============================================

# Ruta a la base de datos SQLite (si deseas migrar datos)
SQLITE_DB_PATH=./db/jwmantto.db
